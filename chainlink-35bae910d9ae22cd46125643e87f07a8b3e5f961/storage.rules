rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    match /Achievements/{allPaths=**} {
      allow read: if true;
    }

    match /Sponsors/{allPaths=**} {
      allow read: if true;
    }
  }
}
