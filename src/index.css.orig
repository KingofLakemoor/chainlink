@import url('https://fonts.googleapis.com/css2?family=Alegreya+SC:wght@400;500;700;800;900&family=Inter:wght@400;500;600;700;800&display=swap');
@import "tailwindcss";

@theme {
  --font-sans: "Inter", ui-sans-serif, system-ui, sans-serif;
  --font-display: "Alegreya SC", serif;

  --animate-vault-rotate: vault-rotate 40s linear infinite;
  --animate-vault-pulse: vault-pulse 6s ease-in-out infinite;
  --animate-gold-dust: gold-dust 8s linear infinite;
  --animate-opulento-sparkle: opulento-sparkle 5s ease-in-out infinite;
  --animate-vault-ring-rotate: vault-ring-rotate 22s linear infinite;
  --animate-vault-lock-pulse: vault-lock-pulse 4s ease-in-out infinite;
  --animate-zero-title-flicker: zero-title-flicker 2.8s infinite;
  --animate-zero-title-glitch-1: zero-title-glitch-1 3.2s infinite;
  --animate-zero-title-glitch-2: zero-title-glitch-2 3.2s infinite;
  --animate-zero-ring-rotate: zero-ring-rotate 22s linear infinite;
  --animate-zero-ring-pulse: zero-ring-pulse 5s ease-in-out infinite;
  --animate-zero-buzzer-node: zero-buzzer-node 1.8s ease-in-out infinite;

  @keyframes vault-rotate {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  @keyframes vault-pulse {
    0%, 100% { opacity: 0.6; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.12); }
  }

  @keyframes gold-dust {
    0% { transform: translateY(0px); opacity: 0.2; }
    50% { opacity: 0.8; }
    100% { transform: translateY(-40px); opacity: 0.1; }
  }

  @keyframes opulento-sparkle {
    0%, 100% { filter: drop-shadow(0 0 8px rgba(250,204,21,0.4)); }
    50% { filter: drop-shadow(0 0 16px rgba(250,204,21,0.9)); }
  }

  @keyframes vault-ring-rotate {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  @keyframes vault-lock-pulse {
    0%, 100% { transform: scale(1); opacity: 0.7; }
    50% { transform: scale(1.25); opacity: 1; }
  }

  /* Title flicker */
  @keyframes zero-title-flicker {
    0%, 100% { opacity: 1; }
    45% { opacity: 0.85; }
    47% { opacity: 0.4; }
    50% { opacity: 1; }
  }

  /* Glitch layers */
  @keyframes zero-title-glitch-1 {
    0%, 100% { transform: translate(0,0); opacity: 0; }
    10% { transform: translate(-2px,1px); opacity: 0.4; }
    12% { transform: translate(0,0); opacity: 0; }
  }

  @keyframes zero-title-glitch-2 {
    0%, 100% { transform: translate(0,0); opacity: 0; }
    55% { transform: translate(2px,-1px); opacity: 0.4; }
    57% { transform: translate(0,0); opacity: 0; }
  }

  /* Ring rotation */
  @keyframes zero-ring-rotate {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(-360deg); }
  }

  /* Ring pulse */
  @keyframes zero-ring-pulse {
    0%, 100% { opacity: 0.6; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.12); }
  }

  /* Buzzer node pulse */
  @keyframes zero-buzzer-node {
    0%, 100% { transform: scale(1); opacity: 0.8; }
    50% { transform: scale(1.4); opacity: 1; }
  }
}

@layer base {
  body {
    @apply bg-[#0a0a0a] text-zinc-50 antialiased;
  }
}
